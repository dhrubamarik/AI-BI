<div class="sidebar-fixed bg-slate-900 text-slate-100 border-r border-slate-800">

    <div class="p-5 border-b border-slate-800 flex-shrink-0">
        <div class="flex items-center space-x-3">
            <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-900/40">
                <i class="fas fa-brain text-white text-sm"></i>
            </div>
            <div>
                <h1 class="text-sm font-bold tracking-tight text-white">AI BI Dashboard</h1>
                <p class="text-[11px] text-slate-400 font-medium">Business Intelligence</p>
            </div>
        </div>
    </div>

    <div class="p-4 border-b border-slate-800 bg-slate-950/40 flex-shrink-0">
        <p class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider mb-2">Currently Analyzing</p>
        <div class="flex items-center space-x-3 bg-slate-800/50 p-2.5 rounded-xl border border-slate-800">
            <% if(activeFile){ %>
                <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse flex-shrink-0 shadow-lg shadow-emerald-400/50"></div>
                <div class="overflow-hidden">
                    <p class="text-xs text-emerald-400 font-semibold truncate"><%= activeFile.fileName %></p>
                    <p class="text-[11px] text-slate-400 mt-0.5"><%= activeFile.totalRows %> rows • <%= activeFile.domain %></p>
                </div>
            <% } else { %>
                <div class="w-2 h-2 bg-slate-500 rounded-full flex-shrink-0"></div>
                <p class="text-xs text-slate-400">No active dataset</p>
            <% } %>
        </div>
    </div>

    <div class="p-4 border-b border-slate-800 flex-shrink-0">
        <p class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider mb-2.5">Upload New File</p>
        <div id="uploadArea" 
             class="border border-dashed border-slate-700 bg-slate-800/20 rounded-xl p-4 text-center hover:border-blue-500 hover:bg-slate-800/40 transition-all cursor-pointer group"
             onclick="document.getElementById('csvFileInput').click()">
            <i class="fas fa-cloud-upload-alt text-slate-500 text-xl mb-1.5 group-hover:text-blue-400 transition-colors"></i>
            <p class="text-xs font-medium text-slate-300 group-hover:text-white transition-colors">Click to select CSV</p>
            <p id="selectedFileName" class="text-xs text-blue-400 font-medium mt-1.5 truncate hidden"></p>
        </div>
        
        <input type="file" id="csvFileInput" accept=".csv" class="hidden">
        
        <button id="uploadBtn" onclick="uploadFile()"
                class="hidden w-full mt-3 bg-blue-600 hover:bg-blue-500 text-white text-xs font-semibold py-2.5 px-4 rounded-xl transition-all shadow-lg shadow-blue-900/20 flex items-center justify-center space-x-2 active:scale-[0.98]">
            <i class="fas fa-upload text-[10px]"></i>
            <span>Upload & Analyze</span>
        </button>

        <div id="uploadProgress" class="hidden mt-3 bg-slate-800 p-2.5 rounded-xl border border-slate-700">
            <div class="bg-slate-700 rounded-full h-1.5 overflow-hidden">
                <div id="progressBar" class="bg-blue-500 h-1.5 rounded-full transition-all duration-500" style="width:0%"></div>
            </div>
            <p id="progressText" class="text-[11px] text-slate-400 mt-1 text-center font-medium">Uploading dynamic dataset...</p>
        </div>
    </div>

    <div class="flex-1 overflow-y-auto p-4 sidebar-scroll flex flex-col min-h-0">
        <p class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider mb-3 sticky top-0 bg-slate-900 py-1">Your Files</p>
        
        <% if(fileHistory && fileHistory.length > 0){ %>
            <div class="space-y-2.5 overflow-y-auto pr-0.5" id="fileHistoryList">
                <% fileHistory.forEach(function(file){ %>
                    <div class="bg-slate-800/40 rounded-xl p-3 border <%= activeFile && activeFile._id.toString() === file._id.toString() ? 'border-blue-500 bg-slate-800/80' : 'border-slate-800' %> hover:border-slate-700 transition-all">
                        
                        <div class="flex items-start justify-between mb-2.5">
                            <div class="flex-1 overflow-hidden pr-2">
                                <p class="text-xs font-semibold text-white truncate"><%= file.fileName %></p>
                                <p class="text-[11px] text-slate-400 mt-0.5"><%= file.totalRows %> rows • <%= file.domain %></p>
                                <p class="text-[10px] text-slate-500 mt-0.5 font-medium">
                                    <%= new Date(file.uploadedAt).toLocaleDateString() %>
                                </p>
                            </div>
                            <% if(activeFile && activeFile._id.toString() === file._id.toString()){ %>
                                <span class="text-[10px] bg-blue-600/20 text-blue-400 border border-blue-500/30 px-1.5 py-0.5 rounded-md font-semibold flex-shrink-0">Active</span>
                            <% } %>
                        </div>

                        <div class="flex space-x-2 items-center">
                            <% if(!activeFile || activeFile._id.toString() !== file._id.toString()){ %>
                                <button onclick="setActiveFile('<%= file._id %>')"
                                        class="flex-1 text-[11px] bg-slate-700 hover:bg-blue-600 text-slate-200 hover:text-white font-medium py-1 px-2.5 rounded-lg transition-all">
                                    Use Dataset
                                </button>
                            <% } else { %>
                                <span class="flex-1 text-[11px] text-left text-emerald-400 font-semibold py-1">
                                    <i class="fas fa-check-circle mr-1"></i>Active Data
                                </span>
                            <% } %>
                            <button onclick="deleteFile('<%= file._id %>')"
                                    class="text-xs text-slate-500 hover:text-red-400 p-1.5 rounded-md transition-colors"
                                    title="Delete File">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="text-center py-10 my-auto">
                <i class="fas fa-folder-open text-slate-700 text-2xl mb-2"></i>
                <p class="text-xs text-slate-400 font-medium">No files uploaded yet</p>
                <p class="text-[11px] text-slate-500 mt-0.5">Upload a CSV to start analyzing</p>
            </div>
        <% } %>
    </div>

    <div class="p-4 border-t border-slate-800 bg-slate-950/30 flex-shrink-0">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3 overflow-hidden">
                <div class="w-8 h-8 bg-gradient-to-tr from-blue-600 to-indigo-600 rounded-lg flex items-center justify-center flex-shrink-0 shadow-md">
                    <span class="text-xs font-bold text-white">
                        <%= user.username.charAt(0).toUpperCase() %>
                    </span>
                </div>
                <div class="overflow-hidden">
                    <p class="text-xs font-semibold text-slate-200 truncate leading-tight"><%= user.username %></p>
                    <p class="text-[11px] text-slate-400 truncate mt-0.5"><%= user.email %></p>
                </div>
            </div>
            <button onclick="logout()" 
                    title="Logout"
                    class="text-slate-500 hover:text-red-400 transition-colors p-1.5 rounded-md ml-2 flex-shrink-0">
                <i class="fas fa-sign-out-alt"></i>
            </button>
        </div>
    </div>
</div>